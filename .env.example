# ──────────────────────────────────────────────────────────────────
#  .env — copia este fichero a .env y rellena las claves.
#
#  IMPORTANTE (equipo de 2 personas, mismas cuentas):
#  · El .env NUNCA se sube a git (está en .gitignore). Es solo local.
#  · Compartíos las mismas keys por un canal seguro (gestor de
#    contraseñas, etc.) — NUNCA por chat ni en un commit.
#  · Todo lo demás (scripts, prompts, timings) SÍ va en git, así que
#    con solo rellenar este .env el pipeline funciona igual para los dos.
# ──────────────────────────────────────────────────────────────────

# === ElevenLabs (voz) ===
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=ZSWlW01JDqJRQML1cHGs
ELEVENLABS_MODEL_ID=eleven_v3
ELEVENLABS_STABILITY=0.45
ELEVENLABS_SIMILARITY_BOOST=0.80
ELEVENLABS_STYLE=0.30
ELEVENLABS_SPEAKER_BOOST=true

# === Higgsfield (imágenes) — motor LEGACY, mantener por si se necesita puntualmente ===
# API key de la CUENTA COMPARTIDA (Higgsfield → Settings → API key).
HIGGSFIELD_API_KEY=
HIGGSFIELD_MCP_URL=https://mcp.higgsfield.ai/mcp
HIGGSFIELD_MODEL=nano_banana_pro
HIGGSFIELD_ASPECT_RATIO=16:9
# Estilo base del canal — prefijo de TODOS los prompts de imagen:
HIGGSFIELD_STYLE_BASE=Simple stickman drawing on white paper, hand-drawn thick black marker lines, muscular stickman character with long hair, headband, red glasses. Red glasses are the ONLY color accent. Pure white background. Minimal, clean.

# === Gemini vía Vertex AI (imágenes) — motor POR DEFECTO desde jul-2026 ===
# El crédito de bienvenida de Google Cloud NO se puede gastar en AI Studio/Gemini Developer
# API (excluido desde política mar-2026) — solo en Vertex AI. Auth por ADC (Application
# Default Credentials), no por API key. Configurar una vez por máquina:
#   gcloud auth application-default login
#   gcloud auth application-default set-quota-project <PROJECT_ID>
#   gcloud auth login && gcloud config set project <PROJECT_ID>
#   gcloud services enable aiplatform.googleapis.com --project=<PROJECT_ID>
GEMINI_VERTEX_PROJECT=
GEMINI_VERTEX_LOCATION=us-central1
# gemini-3-pro-image-preview SOLO responde en location=global (da 404 en regiones concretas).
GEMINI_VERTEX_LOCATION_PRO=global
GEMINI_IMAGE_MODEL_PRO=gemini-3-pro-image-preview
GEMINI_IMAGE_MODEL_FLASH=gemini-2.5-flash-image
GEMINI_ASPECT_RATIO=16:9

# === Whisper (timestamps) ===
WHISPER_ENGINE=faster
WHISPER_MODEL=base
WHISPER_LANGUAGE=es
